@model Website.Test.Models.Catalog.GeneratedProduct
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@(string.IsNullOrEmpty(Model.Title) ? Model.Name : Model.Title)</title>
    <style>
        body { font-family: system-ui, sans-serif; max-width: 42rem; margin: 3rem auto; padding: 0 1rem; line-height: 1.5; color: #1a1a1a; }
        .badge { display: inline-block; background: #0a7d33; color: #fff; font-size: .72rem; letter-spacing: .05em; text-transform: uppercase; padding: .2rem .55rem; border-radius: 4px; }
        h1 { margin: .4rem 0 .25rem; }
        dl { display: grid; grid-template-columns: max-content 1fr; gap: .4rem 1.25rem; margin-top: 1.5rem; }
        dt { font-weight: 600; color: #555; }
        dd { margin: 0; }
        code { background: #f2f2f2; padding: .1rem .3rem; border-radius: 3px; }
        .foot { margin-top: 2rem; font-size: .85rem; color: #777; }
    </style>
</head>
<body>
    <span class="badge">Product view · rendered via CmsSlugs</span>
    <h1>@Model.Name</h1>
    @if (!string.IsNullOrEmpty(Model.Title))
    {
        <p>@Model.Title</p>
    }
    <dl>
        <dt>Code</dt><dd><code>@Model.Code</code></dd>
        <dt>Slug</dt><dd><code>@Model.RouteSegment</code></dd>
        <dt>Content link</dt><dd><code>@Model.ContentLink</code></dd>
    </dl>
    <p class="foot">Rendered by GeneratedProductController &rarr; Views/GeneratedProduct/Index.cshtml. If you see this styled page, the slug resolved to real catalog content and went through the normal template pipeline (not the fallback).</p>
    <p><a href="/">&larr; Back to harness home</a></p>
</body>
</html>
